// ---------------------------------------------------------------------------
// GardenOS – Database Schema
// ---------------------------------------------------------------------------
// Users + invite codes for access control.
// Garden data is synced between localStorage (cache) and the database
// (source of truth) via /api/sync.
// ---------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// User – anyone who can log in
// ---------------------------------------------------------------------------
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String   // bcrypt hash
  role      String   @default("user") // "admin" | "user"
  feedbackEnabled Boolean @default(false)
  maxDesigns Int      @default(3) // admin-configurable per-user design limit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Invite codes created by this user (admin only)
  createdInvites InviteCode[] @relation("CreatedBy")
  // The invite code used to register
  usedInvite     InviteCode?  @relation("UsedBy")
  usedInviteId   String?      @unique

  // Garden data blobs (key-value)
  data UserData[]

  // Saved garden designs (limit per user via maxDesigns)
  designs SavedDesign[]

  // Feedback
  feedback       Feedback[]
  feedbackReplies FeedbackReply[]

  // Icon bank submissions
  iconSubmissions IconBank[]

  // Activity tracking
  lastLoginAt DateTime?
  activityLog ActivityLog[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// UserData – per-user key→JSON store (synced with localStorage)
// ---------------------------------------------------------------------------
model UserData {
  id        String   @id @default(cuid())
  userId    String
  key       String   // e.g. "layout:v1", "plants:custom:v1"
  value     String   // JSON-encoded blob
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_data")
}

// ---------------------------------------------------------------------------
// InviteCode – one-time-use codes for registration
// ---------------------------------------------------------------------------
model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique // 8-char random code
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  expiresAt DateTime? // optional expiry

  // Who created the invite
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])
  createdById String

  // Who used the invite (null = still available)
  usedBy   User?   @relation("UsedBy", fields: [usedById], references: [id])
  usedById String? @unique

  @@map("invite_codes")
}

// ---------------------------------------------------------------------------
// Feedback – user-submitted bugs, ideas, and feature requests
// ---------------------------------------------------------------------------
model Feedback {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "bug" | "idea" | "question" | "other"
  title       String
  description String
  imageData   String?  // base64 image data (optional screenshot/photo)
  status      String   @default("new") // "new" | "read" | "in-progress" | "fixed" | "closed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies FeedbackReply[]

  @@index([userId])
  @@index([status])
  @@map("feedback")
}

// ---------------------------------------------------------------------------
// IconBank – AI-generated icons awaiting admin approval
// ---------------------------------------------------------------------------
model IconBank {
  id          String   @id @default(cuid())
  imageData   String   // base64 data URL of the icon
  prompt      String   // description used to generate
  status      String   @default("pending") // "pending" | "approved" | "rejected"
  submittedBy String   // userId who generated it
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?

  user User @relation(fields: [submittedBy], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([submittedBy])
  @@map("icon_bank")
}

// ---------------------------------------------------------------------------
// FeedbackReply – conversation thread on a feedback item
// ---------------------------------------------------------------------------
model FeedbackReply {
  id         String   @id @default(cuid())
  feedbackId String
  userId     String
  message    String
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
  @@map("feedback_replies")
}

// ---------------------------------------------------------------------------
// SavedDesign – user's saved garden map designs (max 3 per user)
// ---------------------------------------------------------------------------
model SavedDesign {
  id        String   @id @default(cuid())
  userId    String
  name      String   // user-given name, e.g. "Forår 2026", "Drømmehaven"
  layout    String   // JSON-encoded GeoJSON FeatureCollection
  plants    String   @default("[]") // JSON-encoded PlantInstance[]
  thumbnail String?  // optional small base64 preview image
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions DesignVersion[]

  @@index([userId])
  @@map("saved_designs")
}

// ---------------------------------------------------------------------------
// DesignVersion – automatic snapshots kept when a design is overwritten
// ---------------------------------------------------------------------------
model DesignVersion {
  id        String   @id @default(cuid())
  designId  String
  layout    String   // JSON-encoded GeoJSON FeatureCollection (snapshot)
  plants    String   @default("[]") // JSON-encoded PlantInstance[] (snapshot)
  savedAt   DateTime @default(now()) // when the snapshot was taken

  design SavedDesign @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId])
  @@map("design_versions")
}

// ---------------------------------------------------------------------------
// ActivityLog – tracks user actions for admin insight
// ---------------------------------------------------------------------------
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // "login" | "chat" | "scan" | "create-feature" | "tab:xxx" etc.
  detail    String?  // optional extra info e.g. "plant-scan", "soil-scan"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_log")
}
