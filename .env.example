# ──────────────────────────────────────────────────────────────
# GardenOS – Environment Variables
# ──────────────────────────────────────────────────────────────
# Kopiér denne fil til .env og udfyld værdierne.
# VIGTIG: .env er i .gitignore – commit den ALDRIG.
# ──────────────────────────────────────────────────────────────

# ── Database (PostgreSQL via Neon) ──
# Opret gratis database på https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Auth.js ──
# Generér med: openssl rand -base64 32
AUTH_SECRET="din-hemmelige-nøgle-her"

# Sæt til din deployed URL i produktion (Vercel sætter dette automatisk)
# AUTH_URL="https://dit-domæne.vercel.app"

# ── OpenAI (til plante-scan / billedgenkendelse) ──
# Hent API-nøgle fra https://platform.openai.com/api-keys
# På Vercel: Settings → Environment Variables → OPENAI_API_KEY
OPENAI_API_KEY="sk-..."

# ── Admin seed (kun til scripts/seed-admin.ts) ──
ADMIN_EMAIL="admin@gardenos.dk"
ADMIN_PASSWORD="skift-mig-efter-login"

# ── SMTP (til invitation-emails) ──
# Valgfrit – uden SMTP vises login-detaljer i admin-panelet til manuel deling.
# Gmail eksempel: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Brug "App password" fra Google: https://myaccount.google.com/apppasswords
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="GardenOS <noreply@gardenos.dk>"

# ── Datafordeler (matrikelkort) ──
# Brugerens egne credentials konfigureres i appen (Visning → Matrikel).
# Demo-credentials bruges som fallback-knap i UI'et.
# Registrér tjenestebruger på: https://selfservice.datafordeler.dk
NEXT_PUBLIC_DATAFORDELER_DEMO_USER=""
NEXT_PUBLIC_DATAFORDELER_DEMO_PASS=""
